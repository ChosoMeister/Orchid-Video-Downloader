{
  "manifest_version": 3,
  "name": "Orchid Video Downloader",
  "version": "1.0.0",
  "description": "A secure, clean-room universal media stream detector and downloader for HLS, DASH, and progressive video formats.",
  "permissions": [
    "webRequest",
    "storage",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "extension/src/popup/index.html",
    "default_icon": {
      "16": "icons/orchid.png",
      "48": "icons/orchid.png",
      "128": "icons/orchid.png"
    }
  },
  "icons": {
    "16": "icons/orchid.png",
    "48": "icons/orchid.png",
    "128": "icons/orchid.png"
  }
}
